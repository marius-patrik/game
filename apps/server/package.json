{
  "name": "@game/server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "grant-admin": "bun src/scripts/grant-admin.ts"
  },
  "dependencies": {
    "@colyseus/bun-websockets": "^0.16.0",
    "@colyseus/core": "^0.16.0",
    "@colyseus/monitor": "^0.16.0",
    "@colyseus/schema": "^3.0.0",
    "@game/shared": "workspace:*",
    "better-auth": "^1.1.0",
    "drizzle-orm": "^0.38.0",
    "express": "^5.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/express": "^5.0.6",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.2"
  }
}
